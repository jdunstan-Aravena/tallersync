// TallerSync — schema.prisma
// Stack: Next.js + Prisma + PostgreSQL
// Fixes aplicados:
//   1. CategoriaRepuesto agregada correctamente con relación a Repuesto
//   2. Cliente ahora tiene organizacionId (multi-tenancy correcto)
//   3. Notificacion tiene canal (EMAIL / WHATSAPP / LINK_WHATSAPP) y telefonoDestino

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// MULTI-TENANCY
// ─────────────────────────────────────────────

model Organizacion {
  id       String   @id @default(cuid())
  nombre   String
  logo     String?
  plan     Plan     @default(FREE)
  activa   Boolean  @default(true)
  creadoEn DateTime @default(now())

  locales             Local[]
  usuarios            Usuario[]
  clientes            Cliente[]
  categoriasRepuestos CategoriaRepuesto[]

  @@map("organizaciones")
}

enum Plan {
  FREE
  PRO
}

// ─────────────────────────────────────────────
// LOCALES Y USUARIOS
// ─────────────────────────────────────────────

model Local {
  id        String   @id @default(cuid())
  nombre    String
  slug      String   @unique
  direccion String?
  telefono  String?
  email     String?
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id])

  usuarios      UsuarioLocal[]
  ordenes       OrdenTrabajo[]
  ordenesCompra OrdenCompra[]
  repuestos     Repuesto[]

  @@map("locales")
}

model Usuario {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  passwordHash String
  rol          Rol      @default(TECNICO)
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now())

  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id])

  locales                    UsuarioLocal[]
  ordenesAsignadas           OrdenTrabajo[] @relation("TecnicoOrdenes")
  ordenesCreadas             OrdenTrabajo[] @relation("CreadoByOrdenes")
  ordenesCompraCreadas       OrdenCompra[]  @relation("CreadoByOrdenesCompra")
  ordenesCompraAsignadas     OrdenCompra[]  @relation("TecnicoAsignadoOrdenesCompra")
  historialCambios           HistorialOT[]

  @@map("usuarios")
}

enum Rol {
  ADMIN      // Ve todo, configura la organización
  RECEPCION  // Crea OTs, atiende clientes
  TECNICO    // Ve y actualiza sus OTs asignadas
}

model UsuarioLocal {
  id          String  @id @default(cuid())
  esPrincipal Boolean @default(false)

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  localId String
  local   Local  @relation(fields: [localId], references: [id])

  @@unique([usuarioId, localId])
  @@map("usuarios_locales")
}

// ─────────────────────────────────────────────
// CLIENTES Y EQUIPOS
// ─────────────────────────────────────────────

model Cliente {
  id               String   @id @default(cuid())
  nombre           String
  email            String?
  telefono         String?
  rut              String?
  notas            String?
  tokenSeguimiento String   @unique @default(cuid())
  creadoEn         DateTime @default(now())
  actualizadoEn    DateTime @updatedAt

  // FIX 2: organizacionId agregado para correcto aislamiento multi-tenant
  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id])

  equipos        Equipo[]
  ordenes        OrdenTrabajo[]
  notificaciones Notificacion[]

  @@map("clientes")
}

model Equipo {
  id          String     @id @default(cuid())
  tipo        TipoEquipo
  marca       String
  modelo      String
  numeroSerie String?
  color       String?
  accesorios  String?
  notas       String?
  creadoEn    DateTime   @default(now())

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  ordenes OrdenTrabajo[]

  @@map("equipos")
}

enum TipoEquipo {
  CELULAR
  TABLET
  NOTEBOOK
  PC_ESCRITORIO
  CONSOLA
  ELECTRODOMESTICO
  OTRO
}

// ─────────────────────────────────────────────
// ORDEN DE TRABAJO — entidad central
// ─────────────────────────────────────────────

model OrdenTrabajo {
  id     String   @id @default(cuid())
  numero Int
  estado EstadoOT @default(RECIBIDO)

  falla       String
  diagnostico String?
  solucion    String?

  condicionIngreso    String?
  garantiaDias        Int      @default(30)
  requierePresupuesto Boolean  @default(false)
  presupuestoAprobado Boolean?

  fechaIngreso    DateTime  @default(now())
  fechaCompromiso DateTime?
  fechaEntrega    DateTime?

  totalManoObra  Decimal @default(0) @db.Decimal(10, 2)
  totalRepuestos Decimal @default(0) @db.Decimal(10, 2)
  total          Decimal @default(0) @db.Decimal(10, 2)

  tokenPublico  String   @unique @default(cuid())
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  equipoId String
  equipo   Equipo @relation(fields: [equipoId], references: [id])

  localId String
  local   Local  @relation(fields: [localId], references: [id])

  tecnicoId String?
  tecnico   Usuario? @relation("TecnicoOrdenes", fields: [tecnicoId], references: [id])

  creadoPorId String
  creadoPor   Usuario @relation("CreadoByOrdenes", fields: [creadoPorId], references: [id])

  fotos          FotoOT[]
  items          ItemOT[]
  historial      HistorialOT[]
  notificaciones Notificacion[]

  @@unique([localId, numero])
  @@map("ordenes_trabajo")
}

enum EstadoOT {
  RECIBIDO
  EN_DIAGNOSTICO
  ESPERANDO_REPUESTO
  EN_REPARACION
  CONTROL_CALIDAD
  LISTO_RETIRO
  ENTREGADO
  CANCELADO
}

// ─────────────────────────────────────────────
// FOTOS DE LA OT
// ─────────────────────────────────────────────

model FotoOT {
  id       String   @id @default(cuid())
  url      String
  key      String
  nombre   String?
  tipo     TipoFoto @default(INGRESO)
  creadoEn DateTime @default(now())

  ordenId String
  orden   OrdenTrabajo @relation(fields: [ordenId], references: [id], onDelete: Cascade)

  @@map("fotos_ot")
}

enum TipoFoto {
  INGRESO
  PROCESO
  ENTREGA
}

// ─────────────────────────────────────────────
// ITEMS DE LA OT
// ─────────────────────────────────────────────

model ItemOT {
  id             String   @id @default(cuid())
  descripcion    String
  cantidad       Int      @default(1)
  precioUnitario Decimal  @db.Decimal(10, 2)
  subtotal       Decimal  @db.Decimal(10, 2)
  tipo           TipoItem @default(MANO_OBRA)
  creadoEn       DateTime @default(now())

  ordenId String
  orden   OrdenTrabajo @relation(fields: [ordenId], references: [id], onDelete: Cascade)

  repuestoId String?
  repuesto   Repuesto? @relation(fields: [repuestoId], references: [id])

  @@map("items_ot")
}

enum TipoItem {
  MANO_OBRA
  REPUESTO
  SERVICIO_EXTERNO
}

// ─────────────────────────────────────────────
// HISTORIAL / AUDITORÍA DE LA OT
// ─────────────────────────────────────────────

model HistorialOT {
  id               String    @id @default(cuid())
  estadoAnterior   EstadoOT?
  estadoNuevo      EstadoOT
  nota             String?
  esVisibleCliente Boolean   @default(false)
  creadoEn         DateTime  @default(now())

  ordenId String
  orden   OrdenTrabajo @relation(fields: [ordenId], references: [id], onDelete: Cascade)

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  @@map("historial_ot")
}

// ─────────────────────────────────────────────
// INVENTARIO DE REPUESTOS
// ─────────────────────────────────────────────

model Repuesto {
  id            String   @id @default(cuid())
  nombre        String
  sku           String?
  descripcion   String?
  precioCompra  Decimal? @db.Decimal(10, 2)
  precioVenta   Decimal  @db.Decimal(10, 2)
  stockActual   Int      @default(0)
  stockMinimo   Int      @default(1)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  localId String
  local   Local  @relation(fields: [localId], references: [id])

  // FIX 1: categoriaId ahora correctamente relacionado con CategoriaRepuesto
  categoriaId String?
  categoria   CategoriaRepuesto? @relation(fields: [categoriaId], references: [id])

  itemsOT          ItemOT[]
  itemsOrdenCompra ItemOrdenCompra[]

  @@unique([localId, sku])
  @@map("repuestos")
}

// ─────────────────────────────────────────────
// CATEGORÍAS DE REPUESTOS
// FIX 1: modelo que faltaba en las migrations anteriores
// ─────────────────────────────────────────────

model CategoriaRepuesto {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id])

  repuestos Repuesto[]

  @@unique([organizacionId, nombre])
  @@map("categorias_repuestos")
}

// ─────────────────────────────────────────────
// ÓRDENES DE COMPRA (reposición de repuestos)
// ─────────────────────────────────────────────

enum EstadoOrdenCompra {
  BORRADOR
  ENVIADA
  RECIBIDA
  CANCELADA
}

model OrdenCompra {
  id            String            @id @default(cuid())
  numero        Int
  estado        EstadoOrdenCompra @default(BORRADOR)
  proveedor     String?
  nota          String?           @db.Text
  total         Decimal           @default(0) @db.Decimal(10, 2)
  creadoEn      DateTime          @default(now())
  actualizadoEn DateTime          @updatedAt

  localId String
  local   Local  @relation(fields: [localId], references: [id])

  creadoPorId String
  creadoPor   Usuario @relation("CreadoByOrdenesCompra", fields: [creadoPorId], references: [id])

  tecnicoAsignadoId String?
  tecnicoAsignado   Usuario? @relation("TecnicoAsignadoOrdenesCompra", fields: [tecnicoAsignadoId], references: [id])

  items ItemOrdenCompra[]

  @@unique([localId, numero])
  @@map("ordenes_compra")
}

model ItemOrdenCompra {
  id            String   @id @default(cuid())
  descripcion   String
  cantidad      Int
  costoUnitario Decimal  @db.Decimal(10, 2)
  subtotal      Decimal  @db.Decimal(10, 2)
  creadoEn      DateTime @default(now())

  ordenCompraId String
  ordenCompra   OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)

  repuestoId String?
  repuesto   Repuesto? @relation(fields: [repuestoId], references: [id])

  @@map("items_orden_compra")
}

// ─────────────────────────────────────────────
// NOTIFICACIONES
// FIX 3: canal agregado (EMAIL / WHATSAPP / LINK_WHATSAPP)
//         telefonoDestino para envíos WhatsApp
// ─────────────────────────────────────────────

model Notificacion {
  id              String            @id @default(cuid())
  tipo            TipoNotificacion
  canal           CanalNotificacion @default(EMAIL)
  asunto          String?           // opcional en WhatsApp
  cuerpo          String            @db.Text
  telefonoDestino String?           // requerido si canal = WHATSAPP o LINK_WHATSAPP
  estadoEnvio     EstadoEnvio       @default(PENDIENTE)
  errorMensaje    String?
  enviadoEn       DateTime?
  creadoEn        DateTime          @default(now())

  ordenId String?
  orden   OrdenTrabajo? @relation(fields: [ordenId], references: [id])

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  @@map("notificaciones")
}

enum TipoNotificacion {
  CAMBIO_ESTADO
  LISTO_RETIRO
  PRESUPUESTO
  RECORDATORIO
}

// FIX 3: nuevo enum para canal de notificación
enum CanalNotificacion {
  EMAIL
  WHATSAPP       // whatsapp-web.js (fase 2)
  LINK_WHATSAPP  // botón wa.me con mensaje prellenado (fase 1, lanzamiento)
}

enum EstadoEnvio {
  PENDIENTE
  ENVIADO
  ERROR
}